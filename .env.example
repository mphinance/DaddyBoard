# DaddyBoard — environment configuration
#
# Copy this file to `.env` and fill in your key. `.env` is gitignored and never
# leaves the device. Loaded automatically by `npm start` / `npm run mock`
# (Node's --env-file-if-exists; no dotenv dependency).
#
# Env vars take priority over config.json. If you prefer a single JSON file,
# use config.json instead (copy config.example.json) — either works.

# Your TraderDaddy Pro API key (required for live mode). Get it from your
# account's Developer API section. Needs API access on your plan.
TD_API_KEY=td_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API origin (optional — this is the default).
TD_BASE_URL=https://api.traderdaddy.pro

# Local port the display is served on (optional — defaults to 4321).
PORT=4321

# Set to true to run in demo/mock mode with built-in fixtures (no key needed).
# MOCK_MODE=true

# Panel-level tuning (featuredTickers, screenerRotation, rotationSeconds,
# timezone) is only configurable via config.json — see config.example.json.
